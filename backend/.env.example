DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# On Render: DATABASE_URL is auto-set by linked database
# For local dev: leave commented to use SQLite
# DATABASE_URL=postgres://lovelle_user:password@localhost:5432/lovelle_db

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@lovelle.com

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://dating-website-ui.onrender.com

# AI/LLM
GROQ_API_KEY=
GEMINI_API_KEY=

# Redis (for Channels, optional on Render)
REDIS_URL=
